{
  "name": "chnttx.github.io",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx vite --port 5173 --strictPort",
    "build": "bunx vite build && bunx vitepress build docs",
    "preview": "bunx vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix",
    "extract": "formatjs extract 'src/**/*.{ts,tsx}' --ignore='**/*.d.ts' --out-file lang/en.json --id-interpolation-pattern '[sha512:contenthash:base64url:10]'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "docs:dev": "vitepress dev docs --port 5174 --strictPort",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev:all": "concurrently -k -n site,docs -c \"#8a5631,#7a4d2b\" \"bunx vite --port 5173 --strictPort\" \"vitepress dev docs --port 5174 --strictPort\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-intl": "^8.1.3"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-formatjs": "^6.3.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.5.4",
    "vite": "^7.2.2",
    "vitepress": "^2.0.0-alpha.15"
  }
}
